# ── Static site (frontend) ──
# Base URL of the API server that handles form submissions.
# Leave empty when running the API on the same origin (dev mode).
NEXT_PUBLIC_API_URL=

# ── API server (backend) ──
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=system-emails@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=system-emails@example.com
CTA_OWNER_EMAILS=contact@inzint.om
